# ── Supabase (email capture on homepage) ─────────────────────────────────────
# These are the SAME values used in the norwich-booking widget repo. The anon
# key is safe to expose; RLS policies on the `subscribers` table restrict what
# it can do (INSERT only, no SELECT/UPDATE/DELETE).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ── Resend (contact form + subscribe notification emails) ────────────────────
# Required for live email delivery. Without it, both /api/contact and
# /api/subscribe fall back to console.log in dev. In Vercel production this
# MUST be set or contact-form submissions will silently fail to notify hello@.
RESEND_API_KEY=re_...
